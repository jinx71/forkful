PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/forkful

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# TheMealDB (keyless — '1' is the public test key the project ships with)
# Leave blank to run with deterministic mock data (offline demo mode).
MEALDB_API_KEY=1
MEALDB_BASE_URL=https://www.themealdb.com/api/json/v1
